<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App_combustiveis.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label 
                Text="Calculadora Etanol vs Gasolina"
                FontSize="24"
                HorizontalOptions="Center"
                FontAttributes="Bold"/>

            <Image
                Source="dotnet_bot.png"
                HeightRequest="150"
                Aspect="AspectFit" />

            <!-- Entrada Etanol -->
            <Entry
                x:Name="txtEtanol"
                Placeholder="Preço do Etanol (R$)"
                Keyboard="Numeric"/>

            <!--gasolina -->
            <Entry
                x:Name="txtGasolina"
                Placeholder="Preço da Gasolina (R$)"
                Keyboard="Numeric"/>

            <!-- Botão de caucular  .-->
            <Button
                Text="Calcular"
                Clicked="OnCalcularClicked"/>

            <!-- saida (qual vale mais) -->
            <Label
                x:Name="lblResultado"
                Text=""
                FontSize="18"
                HorizontalOptions="Center"
                TextColor="Green"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>